---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Services | Eauxptim"
  description="Services offered by Eauxptim for water process optimization, software, digital twins, and technical consulting."
>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Services</p>
      <h1>Services</h1>
      <p class="lead">
        Eauxptim offers technical and digital services for process performance,
        modelling, optimization, and innovation in the water sector.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container cards">
      <article class="card">
        <h2>Process optimization</h2>
        <p>
          Technical studies and optimization strategies for water and wastewater
          treatment processes, with emphasis on performance, control, and
          operational efficiency.
        </p>
      </article>

      <article class="card">
        <h2>Software & SaaS solutions</h2>
        <p>
          Design and development of software tools, dashboards, and SaaS
          platforms for process monitoring, analytics, and decision support.
        </p>
      </article>

      <article class="card">
        <h2>Digital twins</h2>
        <p>
          Development of digital twin solutions integrating models, data, and
          algorithms to support smarter operation and planning.
        </p>
      </article>

      <article class="card">
        <h2>Engineering consulting</h2>
        <p>
          Audit, engineering, and advisory support in process control,
          instrumentation, optimization, and technical system improvement.
        </p>
      </article>

      <article class="card">
        <h2>Algorithms & sensors</h2>
        <p>
          Applied development work involving intelligent algorithms, sensing
          approaches, and data-driven tools for water process applications.
        </p>
      </article>

      <article class="card">
        <h2>Research collaboration & training</h2>
        <p>
          Support for R&D collaborations, technical dissemination, training,
          scientific writing, and innovation-focused projects.
        </p>
      </article>
    </div>
  </section>
</MainLayout>