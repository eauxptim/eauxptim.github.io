---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact | Eauxptim"
  description="Contact Eauxptim for collaborations, technical consulting, and software or digital twin projects."
>
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Contact</p>
      <h1>Contact us</h1>
      <p class="lead">
        Interested in a collaboration, software solution, modelling task, or
        process optimization project? Get in touch.
      </p>
    </div>
  </section>

<section class="section">
  <div class="container two-col">
    <div class="card">
      <h2>General inquiries</h2>
      <p>
        We welcome inquiries related to water and wastewater optimization,
        digital twins, software tools, engineering studies, and research
        collaboration. Please use the contact details below to get in touch
        with Eauxptim.
      </p>

      <ul class="contact-list">
        <li><strong>Email:</strong> <a href="mailto:eauxptim@gmail.com">eauxptim@gmail.com</a></li>
        <li><strong>Phone:</strong> <a href="tel:+32494827212">+32 494 82 72 12</a></li>
        <li><strong>Location:</strong> Belgium</li>
      </ul>
    </div>

      <div class="card">
        <h2>Project topics</h2>
        <ul class="check-list">
          <li>Water and wastewater optimization</li>
          <li>Digital twins and process models</li>
          <li>AI and data-driven decision tools</li>
          <li>Engineering and technical studies</li>
          <li>Research and innovation partnerships</li>
        </ul>
      </div>
    </div>
  </section>
</MainLayout>